# ─────────────────────────────────────────────
#  Pareeksha Bhavan Monitor — environment vars
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── Telegram ──────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_telegram_chat_id_here

# ── Email (SMTP) ───────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_TO=recipient@example.com

# ── Monitor behaviour (optional overrides) ────
# Comma-separated list of keywords to search for
KEYWORDS=Special Examination,Special Exam,One Time Supplementary,One Time Regular Supplementary,Exhausted Chances,CBCSS,2020 Admission,B.Sc,Computer Science,Third Semester

# Base URL of the website being monitored
BASE_URL=https://pareekshabhavan.uoc.ac.in/

# Path to the JSON file tracking already-seen notifications
LAST_SEEN_PATH=data/last_seen.json

# Directory to store downloaded PDFs temporarily
PDF_DOWNLOAD_DIR=data/pdfs

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Number of HTTP retry attempts
MAX_RETRIES=3
